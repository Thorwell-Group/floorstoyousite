{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "trailingSlash": false,
  "redirects": [
    { "source": "/hardwood",                                 "destination": "/services/engineered-wood", "permanent": true },
    { "source": "/laminate",                                 "destination": "/services/laminate",         "permanent": true },
    { "source": "/luxury-vinyl",                             "destination": "/services/vinyl-click",      "permanent": true },
    { "source": "/tile",                                     "destination": "/services/tile",             "permanent": true },
    { "source": "/flooring-store-edmond",                    "destination": "/areas/edmond",              "permanent": true },
    { "source": "/flooring-store-yukon-oklahoma",            "destination": "/areas/yukon",               "permanent": true },
    { "source": "/flooring-store-mustang-oklahoma",          "destination": "/areas/mustang",             "permanent": true },
    { "source": "/flooring-store-midwest-city-oklahoma",     "destination": "/areas/midwest-city",        "permanent": true },
    { "source": "/flooring-store-guthrie-oklahoma",          "destination": "/areas/guthrie",             "permanent": true },
    { "source": "/about-us",                                 "destination": "/about",                     "permanent": true },
    { "source": "/contact-us",                               "destination": "/contact",                   "permanent": true },
    { "source": "/see-our-reviews",                          "destination": "/reviews",                   "permanent": true },
    { "source": "/see-offers",                               "destination": "/financing",                 "permanent": true },
    { "source": "/how-floor-to-you-works",                   "destination": "/how-it-works",              "permanent": true },
    { "source": "/estimate",                                 "destination": "/free-in-home-estimate",     "permanent": true },
    { "source": "/shop",                                     "destination": "/products",                  "permanent": true }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    }
  ]
}
