---
import type { Product } from '../data/products';
export interface Props {
 products: Product[];
 eyebrow?: string;
 heading?: string;
 subhead?: string;
 showCategory?: boolean;
}
const { products, eyebrow = 'In-Stock Catalog', heading = 'Browse Our In-Stock Products', subhead = 'Tap any tile to see the product page and book a free in-home estimate.', showCategory = false } = Astro.props;
---
{products.length > 0 && (
 <section class="container-x py-16 md:py-20">
 <div class="max-w-2xl mx-auto text-center mb-10">
 <p class="eyebrow mb-3">{eyebrow}</p>
 <h2>{heading}</h2>
 <p class="mt-4 text-ink/75">{subhead}</p>
 <p class="mt-3 text-sm text-brand-700 font-medium">{products.length} in-stock SKUs</p>
 </div>
 <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
 {products.map((p) => (
 <a href={`/products/${p.slug}`} class="group no-underline text-center">
 <div class="aspect-square overflow-hidden rounded-xl2 bg-brand-100 shadow-card">
 <img
 src={p.image}
 alt={`${p.name} flooring - in stock at Floors To You OKC`}
 loading="lazy"
 width="400"
 height="400"
 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
 />
 </div>
 <div class="mt-3">
 <p class="text-sm font-semibold text-brand-800 leading-tight group-hover:text-brand-500">{p.name}</p>
 {showCategory && <p class="text-xs text-ink/55 mt-0.5">{p.category.replace(/-/g, ' ')}</p>}
 </div>
 </a>
 ))}
 </div>
 </section>
)}
