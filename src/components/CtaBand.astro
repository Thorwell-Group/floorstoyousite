---
export interface Props { headline?: string; subline?: string; }
const { headline = "Come Home Every Day And Fall In Love With Your Floors.", subline = "Picture rooms that finally feel finished - the kind friends notice the moment they walk in. We bring the samples to you, hand-match them to your home, then handle furniture, baseboards, installation and cleanup. Tasteful transformation, start to finish - with 0% financing and next-day installation." } = Astro.props;
---
<section class="bg-brand-800 text-white">
  <div class="container-x py-14 md:py-20 grid lg:grid-cols-[1.4fr_1fr] gap-8 items-center">
    <div>
      <h2 class="text-white mb-3">{headline}</h2>
      <p class="text-white/85 leading-relaxed">{subline}</p>
      <ul class="mt-5 flex flex-wrap gap-x-5 gap-y-2 text-sm text-white/85">
        <li class="flex items-center gap-2"><span class="text-brand-300" aria-hidden>✓</span> Price-Match Confidence</li>
        <li class="flex items-center gap-2"><span class="text-brand-300" aria-hidden>✓</span> 0% Financing · 24 Months</li>
        <li class="flex items-center gap-2"><span class="text-brand-300" aria-hidden>✓</span> Next-Day Installation</li>
        <li class="flex items-center gap-2"><span class="text-brand-300" aria-hidden>✓</span> Complimentary Design Visit</li>
      </ul>
    </div>
    <div class="flex flex-col sm:flex-row lg:justify-end gap-3">
      <a href="/book/" class="btn bg-brand-500 text-white hover:bg-brand-600">Get My Free Estimate</a>
    </div>
  </div>
</section>
