---
export interface Props { headline?: string; subline?: string; }
const { headline = "Come Home Every Day And Fall In Love With Your Floors.", subline = "Imagine walking in to floors that stop friends and family mid-sentence - the kind that make you the envy of the block. We bring the samples to you, match them to your light and trim, then handle furniture, baseboards, install and cleanup. Lowest price guaranteed, 0% APR for 24 months, installed in as little as 24 hours." } = Astro.props;
---
<section class="bg-brand-800 text-white">
  <div class="container-x py-14 md:py-20 grid lg:grid-cols-[1.4fr_1fr] gap-8 items-center">
    <div>
      <h2 class="text-white mb-3">{headline}</h2>
      <p class="text-white/85 leading-relaxed">{subline}</p>
      <ul class="mt-5 flex flex-wrap gap-x-5 gap-y-2 text-sm text-white/85">
        <li class="flex items-center gap-2"><span class="text-brand-300" aria-hidden>✓</span> Lowest Price Guaranteed</li>
        <li class="flex items-center gap-2"><span class="text-brand-300" aria-hidden>✓</span> 0% APR · 24 Months</li>
        <li class="flex items-center gap-2"><span class="text-brand-300" aria-hidden>✓</span> Next-Day Install</li>
        <li class="flex items-center gap-2"><span class="text-brand-300" aria-hidden>✓</span> Free In-Home Estimate</li>
      </ul>
    </div>
    <div class="flex flex-col sm:flex-row lg:justify-end gap-3">
      <a href="/book" class="btn bg-brand-500 text-white hover:bg-brand-600">Get My Free Estimate</a>
    </div>
  </div>
</section>
