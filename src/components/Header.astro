---
import { services } from '../data/services';
import { areas } from '../data/areas';
import { productCategories, productsByCategory } from '../data/products';
import { proofTopics } from '../data/proof';
import { site } from '../data/site';
---
<header class="sticky top-0 z-50 bg-cream/95 backdrop-blur border-b border-brand-100">
 <div class="container-x flex items-center justify-between h-20">
 <a href="/" class="flex items-center no-underline" aria-label="Floors To You OKC - home">
 <img
 src="/images/brand/floors-to-you-logo.webp"
 alt="Floors To You - Where We Bring The Showroom To You"
 width="617"
 height="255"
 class="h-12 md:h-16 w-auto"
 loading="eager"
 fetchpriority="high"
 />
 </a>

 <nav class="hidden lg:flex items-center gap-7 text-sm font-medium" aria-label="Primary">
 <div class="relative group">
 <button class="flex items-center gap-1 text-ink hover:text-brand-700">Flooring <span aria-hidden>▾</span></button>
 <div class="absolute left-0 top-full pt-3 hidden group-hover:block">
 <ul class="card p-2 w-72">
 {services.map((s) => (
 <li><a href={`/services/${s.slug}`} class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-ink">{s.shortName}</a></li>
 ))}
 <li class="border-t border-brand-100 mt-1 pt-1">
 <a href="/services" class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-brand-700 font-semibold">All Flooring →</a>
 </li>
 </ul>
 </div>
 </div>

 <div class="relative group">
 <button class="flex items-center gap-1 text-ink hover:text-brand-700">Catalog <span aria-hidden>▾</span></button>
 <div class="absolute left-0 top-full pt-3 hidden group-hover:block">
 <ul class="card p-2 w-64">
 <li><a href='/catalog/?product_type=1' class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-ink">Flooring</a></li>
 <li><a href={'/catalog/?product_type=1&prefilter={"productSubtypes":[1]}'} class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-ink">Hardwood</a></li>
 <li class="border-t border-brand-100 mt-1 pt-1">
 <a href="/catalog" class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-brand-700 font-semibold">Full Catalog →</a>
 </li>
 </ul>
 </div>
 </div>

 <div class="relative group">
 <button class="flex items-center gap-1 text-ink hover:text-brand-700">Service Areas <span aria-hidden>▾</span></button>
 <div class="absolute left-0 top-full pt-3 hidden group-hover:block">
 <ul class="card p-2 w-64">
 {areas.map((a) => (
 <li><a href={`/areas/${a.slug}`} class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-ink">{a.city}</a></li>
 ))}
 <li class="border-t border-brand-100 mt-1 pt-1">
 <a href="/areas" class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-brand-700 font-semibold">All Areas →</a>
 </li>
 </ul>
 </div>
 </div>

 <div class="relative group">
 <button class="flex items-center gap-1 text-ink hover:text-brand-700">Shop <span aria-hidden>▾</span></button>
 <div class="absolute left-0 top-full pt-3 hidden group-hover:block">
 <ul class="card p-2 w-72">
 {productCategories.map((c) => {
 const count = productsByCategory(c.slug).length;
 return count > 0 && (
 <li>
 <a href={`/products#${c.slug}`} class="flex items-center justify-between gap-3 px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-ink">
 <span>{c.label}</span>
 <span class="text-xs font-semibold text-brand-500">{count}</span>
 </a>
 </li>
 );
 })}
 <li class="border-t border-brand-100 mt-1 pt-1">
 <a href="/products" class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-brand-700 font-semibold">Shop All In-Stock →</a>
 </li>
 </ul>
 </div>
 </div>

 <div class="relative group">
 <button class="flex items-center gap-1 text-ink hover:text-brand-700">The Proof <span aria-hidden>▾</span></button>
 <div class="absolute left-0 top-full pt-3 hidden group-hover:block">
 <ul class="card p-2 w-64">
 {proofTopics.map((p) => (
 <li><a href={`/proof/${p.slug}`} class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-ink">{p.navLabel}</a></li>
 ))}
 </ul>
 </div>
 </div>

 <div class="relative group">
 <button class="flex items-center gap-1 text-ink hover:text-brand-700">More <span aria-hidden>▾</span></button>
 <div class="absolute right-0 top-full pt-3 hidden group-hover:block">
 <ul class="card p-2 w-48">
 <li><a href="/financing" class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-ink">Financing</a></li>
 <li><a href="/blog" class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-ink">Blog</a></li>
 <li><a href="/about" class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-ink">About</a></li>
 </ul>
 </div>
 </div>
 </nav>

 <div class="flex items-center gap-3">
 <a href={`tel:${site.phoneE164}`} class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700 hover:text-brand-900 no-underline">
 <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0122 16.92z"/></svg>
 {site.phone}
 </a>
 <a href="/book" class="btn-primary text-sm py-2.5">Free Estimate</a>
 <button id="mobile-menu-btn" type="button" class="lg:hidden p-2 text-ink" aria-label="Open menu" aria-controls="mobile-menu" aria-expanded="false">
 <svg id="mobile-menu-icon-open" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
 <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
 </svg>
 <svg id="mobile-menu-icon-close" class="h-7 w-7 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
 <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" />
 </svg>
 </button>
 </div>
 </div>

 <div id="mobile-menu" class="lg:hidden hidden bg-cream border-t border-brand-100 max-h-[calc(100vh-5rem)] overflow-y-auto">
 <nav class="container-x py-4 text-base font-medium" aria-label="Mobile primary">
 <details class="group border-b border-brand-100">
 <summary class="flex items-center justify-between py-3 cursor-pointer text-ink list-none">
 <span>Flooring</span>
 <span class="text-brand-700 transition-transform group-open:rotate-45 text-xl leading-none" aria-hidden="true">+</span>
 </summary>
 <div class="pb-3 pl-2 space-y-1">
 {services.map((s) => (
 <a href={`/services/${s.slug}`} class="block px-3 py-2 rounded-lg text-ink hover:bg-brand-50 no-underline">{s.shortName}</a>
 ))}
 <a href="/services" class="block px-3 py-2 rounded-lg text-brand-700 font-semibold hover:bg-brand-50 no-underline">All Flooring →</a>
 </div>
 </details>

 <details class="group border-b border-brand-100">
 <summary class="flex items-center justify-between py-3 cursor-pointer text-ink list-none">
 <span>Catalog</span>
 <span class="text-brand-700 transition-transform group-open:rotate-45 text-xl leading-none" aria-hidden="true">+</span>
 </summary>
 <div class="pb-3 pl-2 space-y-1">
 <a href='/catalog/?product_type=1' class="block px-3 py-2 rounded-lg text-ink hover:bg-brand-50 no-underline">Flooring</a>
 <a href={'/catalog/?product_type=1&prefilter={"productSubtypes":[1]}'} class="block px-3 py-2 rounded-lg text-ink hover:bg-brand-50 no-underline">Hardwood</a>
 <a href="/catalog" class="block px-3 py-2 rounded-lg text-brand-700 font-semibold hover:bg-brand-50 no-underline">Full Catalog →</a>
 </div>
 </details>

 <details class="group border-b border-brand-100">
 <summary class="flex items-center justify-between py-3 cursor-pointer text-ink list-none">
 <span>Service Areas</span>
 <span class="text-brand-700 transition-transform group-open:rotate-45 text-xl leading-none" aria-hidden="true">+</span>
 </summary>
 <div class="pb-3 pl-2 space-y-1">
 {areas.map((a) => (
 <a href={`/areas/${a.slug}`} class="block px-3 py-2 rounded-lg text-ink hover:bg-brand-50 no-underline">{a.city}</a>
 ))}
 <a href="/areas" class="block px-3 py-2 rounded-lg text-brand-700 font-semibold hover:bg-brand-50 no-underline">All Areas →</a>
 </div>
 </details>

 <details class="group border-b border-brand-100">
 <summary class="flex items-center justify-between py-3 cursor-pointer text-ink list-none">
 <span>Shop</span>
 <span class="text-brand-700 transition-transform group-open:rotate-45 text-xl leading-none" aria-hidden="true">+</span>
 </summary>
 <div class="pb-3 pl-2 space-y-1">
 {productCategories.map((c) => {
 const count = productsByCategory(c.slug).length;
 return count > 0 && (
 <a href={`/products#${c.slug}`} class="flex items-center justify-between gap-3 px-3 py-2 rounded-lg text-ink hover:bg-brand-50 no-underline">
 <span>{c.label}</span>
 <span class="text-xs font-semibold text-brand-500">{count}</span>
 </a>
 );
 })}
 <a href="/products" class="block px-3 py-2 rounded-lg text-brand-700 font-semibold hover:bg-brand-50 no-underline">Shop All In-Stock →</a>
 </div>
 </details>

 <details class="group border-b border-brand-100">
 <summary class="flex items-center justify-between py-3 cursor-pointer text-ink list-none">
 <span>The Proof</span>
 <span class="text-brand-700 transition-transform group-open:rotate-45 text-xl leading-none" aria-hidden="true">+</span>
 </summary>
 <div class="pb-3 pl-2 space-y-1">
 {proofTopics.map((p) => (
 <a href={`/proof/${p.slug}`} class="block px-3 py-2 rounded-lg text-ink hover:bg-brand-50 no-underline">{p.navLabel}</a>
 ))}
 </div>
 </details>

 <details class="group border-b border-brand-100">
 <summary class="flex items-center justify-between py-3 cursor-pointer text-ink list-none">
 <span>More</span>
 <span class="text-brand-700 transition-transform group-open:rotate-45 text-xl leading-none" aria-hidden="true">+</span>
 </summary>
 <div class="pb-3 pl-2 space-y-1">
 <a href="/financing" class="block px-3 py-2 rounded-lg text-ink hover:bg-brand-50 no-underline">Financing</a>
 <a href="/blog" class="block px-3 py-2 rounded-lg text-ink hover:bg-brand-50 no-underline">Blog</a>
 <a href="/about" class="block px-3 py-2 rounded-lg text-ink hover:bg-brand-50 no-underline">About</a>
 </div>
 </details>

 <a href="/book" class="btn-primary block text-center mt-4">Free Estimate</a>
 <a href={`tel:${site.phoneE164}`} class="block text-center mt-2 py-3 text-brand-700 font-semibold no-underline">{site.phone}</a>
 </nav>
 </div>
</header>

<script is:inline>
 (function () {
 var btn = document.getElementById('mobile-menu-btn');
 var menu = document.getElementById('mobile-menu');
 var iconOpen = document.getElementById('mobile-menu-icon-open');
 var iconClose = document.getElementById('mobile-menu-icon-close');
 if (!btn || !menu) return;

 function setOpen(open) {
 if (open) {
 menu.classList.remove('hidden');
 btn.setAttribute('aria-expanded', 'true');
 btn.setAttribute('aria-label', 'Close menu');
 if (iconOpen) iconOpen.classList.add('hidden');
 if (iconClose) iconClose.classList.remove('hidden');
 } else {
 menu.classList.add('hidden');
 btn.setAttribute('aria-expanded', 'false');
 btn.setAttribute('aria-label', 'Open menu');
 if (iconOpen) iconOpen.classList.remove('hidden');
 if (iconClose) iconClose.classList.add('hidden');
 }
 }

 btn.addEventListener('click', function () {
 setOpen(menu.classList.contains('hidden'));
 });

 menu.addEventListener('click', function (e) {
 var t = e.target;
 if (t && t.closest && t.closest('a')) {
 setOpen(false);
 }
 });

 if (window.matchMedia) {
 var mq = window.matchMedia('(min-width: 1024px)');
 var handler = function (ev) { if (ev.matches) setOpen(false); };
 if (mq.addEventListener) mq.addEventListener('change', handler);
 else if (mq.addListener) mq.addListener(handler);
 }

 document.addEventListener('keydown', function (e) {
 if ((e.key === 'Escape' || e.keyCode === 27) && !menu.classList.contains('hidden')) {
 setOpen(false);
 btn.focus();
 }
 });
 })();
</script>
