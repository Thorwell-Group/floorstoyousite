---
import { site } from '../data/site';
import { services } from '../data/services';
import { areas } from '../data/areas';
---
<header class="sticky top-0 z-50 bg-cream/95 backdrop-blur border-b border-brand-100">
 <div class="container-x flex items-center justify-between h-20">
 <a href="/" class="flex items-center no-underline" aria-label="Floors To You OKC - home">
 <img
 src="/images/brand/floors-to-you-logo.webp"
 alt="Floors To You - Where We Bring The Showroom To You"
 width="617"
 height="255"
 class="h-12 md:h-16 w-auto"
 loading="eager"
 fetchpriority="high"
 />
 </a>

 <nav class="hidden lg:flex items-center gap-7 text-sm font-medium" aria-label="Primary">
 <div class="relative group">
 <button class="flex items-center gap-1 text-ink hover:text-brand-700">Flooring <span aria-hidden>▾</span></button>
 <div class="absolute left-0 top-full pt-3 hidden group-hover:block">
 <ul class="card p-2 w-72">
 {services.map((s) => (
 <li><a href={`/services/${s.slug}`} class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-ink">{s.shortName}</a></li>
 ))}
 <li class="border-t border-brand-100 mt-1 pt-1">
 <a href="/services" class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-brand-700 font-semibold">All Flooring →</a>
 </li>
 </ul>
 </div>
 </div>

 <div class="relative group">
 <button class="flex items-center gap-1 text-ink hover:text-brand-700">Service Areas <span aria-hidden>▾</span></button>
 <div class="absolute left-0 top-full pt-3 hidden group-hover:block">
 <ul class="card p-2 w-64">
 {areas.map((a) => (
 <li><a href={`/areas/${a.slug}`} class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-ink">{a.city}</a></li>
 ))}
 <li class="border-t border-brand-100 mt-1 pt-1">
 <a href="/areas" class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-brand-700 font-semibold">All Areas →</a>
 </li>
 </ul>
 </div>
 </div>

 <a href="/products" class="text-ink hover:text-brand-700 no-underline">Shop</a>
 <a href="/financing" class="text-ink hover:text-brand-700 no-underline">Financing</a>
 <a href="/about" class="text-ink hover:text-brand-700 no-underline">About</a>
 </nav>

 <div class="flex items-center gap-3">
 <a href={`tel:${site.phoneTel}`} class="hidden md:inline text-brand-800 font-semibold no-underline hover:text-brand-500">
 {site.phone}
 </a>
 <a href="/free-in-home-estimate" class="btn-primary text-sm py-2.5">Free Estimate</a>
 </div>
 </div>
</header>
