---
import { site } from '../../data/site';

export interface Props {
  name: string;
  description: string;
  slug: string;
  areaServed?: string[];
  image?: string;
}

const { name, description, slug, areaServed = ['Oklahoma City', 'Edmond', 'Yukon', 'Mustang', 'Midwest City', 'Moore', 'Norman', 'Guthrie'], image } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${site.domain}/services/${slug}#service`,
  name,
  description,
  serviceType: name,
  provider: { '@id': `${site.domain}/#business` },
  areaServed: areaServed.map((c) => ({ '@type': 'City', name: `${c}, OK` })),
  ...(image && { image: `${site.domain}${image}` }),
  url: `${site.domain}/services/${slug}`,
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
