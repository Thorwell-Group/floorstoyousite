---
import { site } from '../data/site';
import { services } from '../data/services';
import { areas } from '../data/areas';
const year = new Date().getFullYear();
---
<footer class="bg-brand-900 text-white mt-24">
 <div class="container-x py-16 grid md:grid-cols-2 lg:grid-cols-4 gap-10">
 <div>
 <div class="mb-4">
 <img
 src="/images/brand/floors-to-you-logo.webp"
 alt="Floors To You - Where We Bring The Showroom To You"
 width="617"
 height="255"
 class="h-16 w-auto bg-cream rounded-xl2 p-3"
 loading="lazy"
 />
 </div>
 <p class="text-white/80 text-sm leading-relaxed mb-4">{site.tagline}. Locally owned, locally installed since {site.foundingDate}.</p>
 <address class="not-italic text-sm text-white/80 leading-relaxed">
 {site.address.street}<br/>
 {site.address.city}, {site.address.region} {site.address.postalCode}
 </address>
 <div class="mt-3 space-y-1 text-sm">
 <a href={`tel:${site.phoneE164}`} class="block text-white/80 hover:text-white no-underline">{site.phone}</a>
 <a href={`mailto:${site.email}`} class="block text-white/80 hover:text-white no-underline break-all">{site.email}</a>
 </div>
 </div>

 <div>
 <h4 class="text-white font-display text-lg mb-4">Flooring</h4>
 <ul class="space-y-2 text-sm">
 {services.map((s) => (
 <li><a href={`/services/${s.slug}`} class="text-white/80 hover:text-brand-300 no-underline">{s.shortName}</a></li>
 ))}
 </ul>
 </div>

 <div>
 <h4 class="text-white font-display text-lg mb-4">Service Areas</h4>
 <ul class="space-y-2 text-sm">
 {areas.map((a) => (
 <li><a href={`/areas/${a.slug}`} class="text-white/80 hover:text-brand-300 no-underline">{a.city}, OK</a></li>
 ))}
 </ul>
 </div>

 <div>
 <h4 class="text-white font-display text-lg mb-4">Company</h4>
 <ul class="space-y-2 text-sm">
 <li><a href="/products" class="text-white/80 hover:text-brand-300 no-underline">Shop All Flooring</a></li>
 <li><a href="/about" class="text-white/80 hover:text-brand-300 no-underline">About</a></li>
 <li><a href="/how-it-works" class="text-white/80 hover:text-brand-300 no-underline">How It Works</a></li>
 <li><a href="/blog" class="text-white/80 hover:text-brand-300 no-underline">Blog</a></li>
 <li><a href={site.financingUrl} target="_blank" rel="nofollow noopener" class="text-white/80 hover:text-brand-300 no-underline">Financing</a></li>
 <li><a href="/book" class="text-white/80 hover:text-brand-300 no-underline">Free Estimate</a></li>
 <li><a href="/reviews" class="text-white/80 hover:text-brand-300 no-underline">Reviews</a></li>
 <li><a href="/flooring-faq" class="text-white/80 hover:text-brand-300 no-underline">FAQ</a></li>
 <li><a href="/contact" class="text-white/80 hover:text-brand-300 no-underline">Contact</a></li>
 </ul>
 </div>
 </div>

 <div class="border-t border-white/10">
 <div class="container-x py-6 flex flex-col sm:flex-row items-center justify-between gap-6">
 {/* LEFT: copyright */}
 <div class="text-xs text-white/60 leading-relaxed text-center sm:text-left">
 © {year} {site.legalName}. All rights reserved.
 <div class="mt-1 text-[10px] opacity-80">
 <a href="/privacy" class="hover:text-white no-underline">Privacy</a>
 <span class="mx-2 opacity-40">·</span>
 <a href="/sitemap-index.xml" class="hover:text-white no-underline">Sitemap</a>
 </div>
 </div>

 {/* RIGHT: Thorwell credit */}
 <div class="flex flex-col items-center sm:items-end gap-1.5 leading-none text-center sm:text-right">
 <span class="text-[10px] uppercase tracking-[0.22em] text-white/55 font-semibold">
 Site designed and hosted
 </span>
 <a
 href="https://thorwellgroup.com"
 target="_blank"
 rel="noopener"
 class="text-lg sm:text-xl tracking-[0.06em] text-white font-normal hover:text-[#CBFBB4] transition-colors no-underline"
 >
 Thor<span class="text-[#CBFBB4]">w</span>ell Group Inc.
 </a>
 <a
 href="https://thorwellgroup.com"
 target="_blank"
 rel="noopener"
 class="text-[10px] sm:text-[11px] tracking-[0.32em] text-white/85 hover:text-[#CBFBB4] transition-colors no-underline"
 >
 The future of flooring
 </a>
 </div>
 </div>
 </div>
</footer>
