---
/** Full-bleed lifestyle photo with an overlaid customer quote. */
import PriceGuaranteeBadge from './PriceGuaranteeBadge.astro';
---
<section class="relative overflow-hidden">
  <img
    src="/images/photos/testimonial/mom-baby-floor.webp"
    alt="Mom and laughing baby crawling on a new luxury vinyl plank floor in an Oklahoma City bedroom"
    width="1600"
    height="1067"
    loading="lazy"
    class="absolute inset-0 w-full h-full object-cover"
  />
  <div aria-hidden class="absolute inset-0 bg-gradient-to-r from-brand-900/90 via-brand-900/65 to-brand-900/10"></div>

  <PriceGuaranteeBadge class="absolute bottom-6 right-6 z-10 hidden sm:grid" />

  <div class="container-x relative py-20 md:py-28 lg:py-36">
    <figure class="max-w-xl text-white">
      <div class="flex gap-1 text-brand-300 text-xl mb-5" aria-hidden="true">★★★★★</div>
      <blockquote class="font-display text-2xl sm:text-3xl lg:text-4xl leading-snug">
        <span class="text-brand-300">"</span>Floors To You saved us hundreds of dollars and hours of looking. Now our friends and family are setting appointments - don't go anywhere else.<span class="text-brand-300">"</span>
      </blockquote>
      <figcaption class="mt-6 text-white/80 text-sm uppercase tracking-[0.18em] font-semibold">
        Verified Floors To You OKC Homeowner
      </figcaption>
      <a href="/book" class="btn-primary mt-8">Get My Free Estimate</a>
    </figure>
  </div>
</section>
