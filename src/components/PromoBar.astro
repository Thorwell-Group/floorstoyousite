---
import { site } from '../data/site';
const perks = [
  'Free In-Home Estimate',
  'Lowest Price Guaranteed',
  '0% APR for 24 Months',
  'Next-Day Install Available',
];
---
<div class="bg-brand-800 text-white text-sm">
  <div class="container-x flex items-center justify-center gap-x-6 gap-y-1 py-2 flex-wrap">
    <ul class="flex items-center gap-x-5 gap-y-1 flex-wrap justify-center font-medium">
      {perks.map((p) => (
        <li class="flex items-center gap-1.5">
          <span class="text-brand-300" aria-hidden>✓</span>
          <span class="text-white/90">{p}</span>
        </li>
      ))}
    </ul>
    <a href={`tel:${site.phoneE164}`} class="hidden md:inline-flex items-center gap-1.5 font-semibold text-white hover:text-brand-300 no-underline">
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0122 16.92z"/></svg>
      {site.phone}
    </a>
  </div>
</div>
