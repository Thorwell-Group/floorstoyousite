---
import { site } from '../data/site';
---
<section class="container-x py-16 md:py-24">
  <div class="text-center max-w-2xl mx-auto mb-12">
    <p class="eyebrow mb-3">Why Floors To You OKC</p>
    <h2>We Do The Heavy Lifting. You Just Pick The Floor.</h2>
    <p class="mt-4 text-ink/75">From the first sample to the last baseboard, we handle every step - so all you have to do is walk in and say <em>"wow."</em></p>
  </div>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {site.promises.map((p) => (
      <div class="card p-6">
        <div class="text-brand-500 text-3xl mb-3" aria-hidden>✓</div>
        <p class="font-display text-lg text-brand-800">{p}</p>
      </div>
    ))}
  </div>
</section>
