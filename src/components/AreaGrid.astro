---
import { areas } from '../data/areas';
export interface Props { serviceSlug?: string; serviceName?: string; }
const { serviceSlug, serviceName } = Astro.props;
---
<section class="bg-brand-50">
  <div class="container-x py-16 md:py-24">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <p class="eyebrow mb-3">Where We Install</p>
      <h2>{serviceName ? `${serviceName} Across The OKC Metro` : 'Proudly Serving Oklahoma City &amp; The Metro'}</h2>
      <p class="mt-4 text-ink/75">Free in-home estimates, next-day install on in-stock materials, and a 100% labor guarantee in every city we serve.</p>
    </div>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {areas.map((a) => (
        <a href={serviceSlug ? `/${a.slug}/${serviceSlug}/` : `/areas/${a.slug}/`} class="card p-5 no-underline hover:shadow-soft transition-shadow">
          <h3 class="text-lg text-brand-800 mb-1">{a.city}, {a.state}</h3>
          <p class="text-sm text-ink/65">{a.drivingMinutes === 0 ? 'Our showroom' : `${a.drivingMinutes} min from showroom`}</p>
        </a>
      ))}
    </div>
  </div>
</section>
