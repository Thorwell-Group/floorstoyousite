---
import { reviews } from '../data/testimonials';
export interface Props { class?: string; }
const { class: cls = '' } = Astro.props;
---
<div class={`grid gap-6 sm:grid-cols-2 lg:grid-cols-3 ${cls}`}>
  {reviews.map((r) => (
    <figure class="flex h-full flex-col rounded-xl2 bg-white ring-1 ring-brand-100 shadow-card p-6 text-left">
      <div class="flex items-center gap-3">
        <span class="grid h-11 w-11 flex-none place-items-center rounded-full bg-brand-500 text-white font-display font-bold text-sm" aria-hidden="true">{r.initials}</span>
        <div class="min-w-0 leading-tight">
          <figcaption class="font-semibold text-brand-800 truncate">{r.name}</figcaption>
          <div class="text-xs text-ink/55">{r.localGuide ? 'Local Guide · ' : ''}{r.date}</div>
        </div>
        <svg class="ml-auto flex-none" width="20" height="20" viewBox="0 0 48 48" aria-hidden="true">
          <path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/>
          <path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/>
          <path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/>
          <path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/>
        </svg>
      </div>
      <div class="mt-4 text-brand-500 text-sm tracking-wide" aria-label={`${r.rating} out of 5 stars`}>{'★'.repeat(r.rating)}</div>
      <blockquote class="mt-2 text-sm leading-relaxed text-ink/80">{r.text}</blockquote>
    </figure>
  ))}
</div>
