---
export interface Props { src: string; title?: string; }
const { src, title = 'Service area map' } = Astro.props;
---
<div class="rounded-xl2 overflow-hidden shadow-card aspect-[16/9] bg-brand-100">
  <iframe
    src={src}
    title={title}
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    class="w-full h-full border-0"
    allowfullscreen
  ></iframe>
</div>
