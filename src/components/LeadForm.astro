---
/**
 * Bare ("no shell") GoHighLevel / LeadConnector survey embed — lazy "facade".
 *
 * The real iframe (which drags in reCAPTCHA ~750KB, intl-tel-input,
 * libphonenumber + cookies) is NOT rendered on load. Instead we render a
 * lightweight skeleton; <LeadFormScript /> swaps in the live iframe only when
 * the placeholder nears the viewport (IntersectionObserver) or is tapped.
 * This keeps the heavy third-party form stack off the initial page load —
 * huge mobile-perf win, and it stops third-party cookies firing on load.
 *
 * Use a unique `instance` per placement so iframe ids don't collide when the
 * form is rendered twice on one page (desktop + mobile). Include
 * <LeadFormScript /> once per page. (`eager` is accepted for backwards
 * compatibility but is a no-op — above-the-fold forms activate immediately via
 * the observer's generous rootMargin.)
 */
export interface Props { instance: string; class?: string; eager?: boolean; }
const { instance, class: cls = '' } = Astro.props;
const iframeId = `fty-survey-${instance}`;
const surveySrc = 'https://api.leadconnectorhq.com/widget/survey/jWARw7xCkBcUAI4uUldA';
---
<div class={cls}>
  <div
    class="fty-form-embed relative w-full cursor-pointer"
    data-fty-form
    data-src={surveySrc}
    data-iframe-id={iframeId}
    data-title="Book a free in-home flooring estimate"
    style="min-height:600px;"
  >
    <div class="fty-form-skeleton absolute inset-0 grid place-items-center rounded-xl2 bg-white/80 ring-1 ring-brand-100">
      <div class="flex flex-col items-center gap-3 text-ink/60">
        <span class="h-7 w-7 animate-spin rounded-full border-2 border-brand-200 border-t-brand-500" aria-hidden="true"></span>
        <span class="text-sm">Loading your free estimate form…</span>
      </div>
    </div>
  </div>
  <p class="mt-3 text-center text-[11px] sm:text-xs text-ink/55 leading-relaxed">
    By submitting, you agree to be contacted by Floors To You OKC. We never share your info.
  </p>
</div>
