---
const proofs = [
  {
    label: 'Life Proof',
    line: 'Furniture, high heels, moving day and everyday wear - tough wear layers keep floors looking new for years.',
    icon: 'shield',
  },
  {
    label: 'Water Proof',
    line: 'Spills, mopping, pet bowls and bath splashes - 100% waterproof luxury vinyl that never warps.',
    icon: 'water',
  },
  {
    label: 'Family Proof',
    line: 'Dropped toys, juice boxes and heavy daily traffic - flooring that shrugs off real family life.',
    icon: 'family',
  },
  {
    label: 'Pet Proof',
    line: 'Claws, zoomies and the occasional accident - scratch- and stain-resistant floors built for paws.',
    icon: 'paw',
  },
  {
    label: 'Mess Proof',
    line: "Wine, markers and muddy shoes - wipe-clean surfaces that don't stain, so messes never leave a mark.",
    icon: 'sparkle',
  },
];
---
<section class="bg-brand-900 text-white py-16 md:py-24">
  <div class="container-x">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <p class="eyebrow text-brand-300 mb-3">Built For Real Oklahoma Life</p>
      <h2 class="text-white">Life Proof. Water Proof. Family Proof. Pet Proof. Mess Proof.</h2>
      <p class="mt-4 text-lg text-white/80 leading-relaxed">
        Beautiful is easy. We sell floors that stay beautiful - engineered to survive kids, pets, spills and every Saturday in between.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5">
      {proofs.map((p) => (
        <div class="rounded-xl2 bg-white/[0.06] ring-1 ring-white/10 p-6 hover:bg-white/[0.1] transition-colors">
          <span class="grid place-items-center w-14 h-14 rounded-full bg-brand-500 text-white mb-5" aria-hidden="true">
            {p.icon === 'water' && (
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.5S5.5 9.5 5.5 14a6.5 6.5 0 0 0 13 0c0-4.5-6.5-11.5-6.5-11.5z"/></svg>
            )}
            {p.icon === 'paw' && (
              <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><circle cx="5.5" cy="11" r="2"/><circle cx="9.5" cy="6.5" r="2"/><circle cx="14.5" cy="6.5" r="2"/><circle cx="18.5" cy="11" r="2"/><path d="M12 12c-2.5 0-4.5 1.8-5.2 3.7-.6 1.6.6 3.3 2.3 3.3.9 0 1.7-.4 2.9-.4s2 .4 2.9.4c1.7 0 2.9-1.7 2.3-3.3C16.5 13.8 14.5 12 12 12z"/></svg>
            )}
            {p.icon === 'family' && (
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="7" r="3"/><circle cx="17" cy="9" r="2"/><path d="M3 20v-1a5 5 0 0 1 5-5h2a5 5 0 0 1 5 5v1"/><path d="M16 14a4 4 0 0 1 4 4v2"/></svg>
            )}
            {p.icon === 'shield' && (
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.5 4 6v6c0 5 3.4 8.2 8 9.5 4.6-1.3 8-4.5 8-9.5V6l-8-3.5z"/><path d="m9 12 2 2 4-4"/></svg>
            )}
            {p.icon === 'sparkle' && (
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.8 4.2L18 9l-4.2 1.8L12 15l-1.8-4.2L6 9l4.2-1.8z"/><path d="M19 14l.8 1.9L22 17l-2.2.9L19 20l-.8-2.1L16 17l2.2-1.1z"/></svg>
            )}
          </span>
          <h3 class="text-white text-xl font-display mb-2">{p.label}</h3>
          <p class="text-sm text-white/75 leading-relaxed">{p.line}</p>
        </div>
      ))}
    </div>

    {/* Price-beat guarantee */}
    <div class="mt-10 rounded-xl2 bg-brand-500 px-6 py-7 sm:px-10 sm:py-8 flex flex-col md:flex-row items-center justify-between gap-5 text-center md:text-left">
      <div class="flex items-center gap-4">
        <span class="grid place-items-center w-14 h-14 flex-none rounded-full bg-white/20 text-white" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.5 4 6v6c0 5 3.4 8.2 8 9.5 4.6-1.3 8-4.5 8-9.5V6l-8-3.5z"/><path d="m9 12 2 2 4-4"/></svg>
        </span>
        <div>
          <p class="font-display text-2xl sm:text-3xl text-white font-bold leading-tight">Designer Floors. Honestly Priced.</p>
          <p class="text-white/90 mt-1 text-sm sm:text-base">Beautiful shouldn't mean overpriced. And if you find the same or similar material quoted for less, we'll beat it - guaranteed.</p>
        </div>
      </div>
      <div class="flex items-center gap-6 flex-none">
        <div class="text-center leading-none">
          <div class="font-display font-bold text-5xl sm:text-6xl text-white">0%</div>
          <div class="text-[10px] sm:text-xs uppercase tracking-[0.18em] text-white/85 mt-1.5">APR · 24 Months</div>
        </div>
        <a href="/book/" class="btn bg-white text-brand-700 hover:bg-brand-50">Request My Quote</a>
      </div>
    </div>
  </div>
</section>
