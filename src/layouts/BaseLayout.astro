---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import PromoBar from '../components/PromoBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LocalBusinessSchema from '../components/schema/LocalBusinessSchema.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
  includeLocalBusiness?: boolean;
}
const { title, description, canonical, image, noindex, includeLocalBusiness = true } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-MCTBQF4ZLL"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-MCTBQF4ZLL');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" />
    <meta name="theme-color" content="#bd9454" />
    <SEO title={title} description={description} canonical={canonical} image={image} noindex={noindex} />
    {includeLocalBusiness && <LocalBusinessSchema />}
    <script
      is:inline
      async
      id="roomvoAssistant"
      type="text/javascript"
      data-locale="en-us"
      data-position="bottom-right"
      src="https://www.roomvo.com/static/scripts/b2b/common/assistant.js"
    ></script>
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 bg-brand-800 text-white px-4 py-2 rounded-lg">Skip to content</a>
    <PromoBar />
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
