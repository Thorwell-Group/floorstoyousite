---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import PromoBar from '../components/PromoBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LocalBusinessSchema from '../components/schema/LocalBusinessSchema.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
  includeLocalBusiness?: boolean;
}
const { title, description, canonical, image, noindex, includeLocalBusiness = true } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-render-blocking web fonts: preload as style, then swap to stylesheet on load. -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" /></noscript>
    <meta name="theme-color" content="#bd9454" />
    <SEO title={title} description={description} canonical={canonical} image={image} noindex={noindex} />
    {includeLocalBusiness && <LocalBusinessSchema />}
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 bg-brand-800 text-white px-4 py-2 rounded-lg">Skip to content</a>
    <PromoBar />
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      // Defer Google Analytics (gtag.js) off the critical render path. Loading it
      // eagerly in <head> cost ~580ms of unused JS and hurt mobile FCP/LCP. We
      // load on the first real interaction, with a 3.5s idle fallback so sessions
      // that never interact are still counted. dataLayer is stubbed immediately
      // so any early gtag() calls queue and replay once the library loads.
      (function () {
        window.dataLayer = window.dataLayer || [];
        window.gtag = function () { dataLayer.push(arguments); };
        gtag('js', new Date());
        gtag('config', 'G-MCTBQF4ZLL');
        var done = false;
        function loadGA() {
          if (done) return;
          done = true;
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-MCTBQF4ZLL';
          document.head.appendChild(s);
        }
        ['scroll', 'pointerdown', 'keydown', 'touchstart', 'mousemove'].forEach(function (ev) {
          window.addEventListener(ev, loadGA, { once: true, passive: true });
        });
        setTimeout(loadGA, 3500);
      })();
    </script>
    <script is:inline>
      // Track click-to-call as a GA4 lead. Phone calls are the #1 lead channel
      // for flooring, and were previously invisible in Analytics. The gtag() stub
      // queues this even before gtag.js finishes loading (the click's own
      // pointerdown triggers the loader above), so it replays once ready.
      document.addEventListener('click', function (e) {
        var a = e.target && e.target.closest ? e.target.closest('a[href^="tel:"]') : null;
        if (!a || typeof gtag !== 'function') return;
        gtag('event', 'phone_call_click', {
          phone_number: a.getAttribute('href').replace('tel:', ''),
          link_location: a.closest('footer') ? 'footer' : (a.closest('header') ? 'header' : 'body'),
        });
      }, { passive: true });
    </script>
    <script is:inline>
      // Defer the Roomvo visualizer assistant until the page is idle or the user
      // first interacts — keeps its script + visitor ping off the critical path
      // (faster FCP/LCP, no third-party error during first paint). Pages with
      // their own in-page Roomvo embed (e.g. /catalog) already load it directly.
      (function () {
        function loadRoomvo() {
          if (document.getElementById('roomvoAssistant')) return;
          var s = document.createElement('script');
          s.id = 'roomvoAssistant';
          s.async = true;
          s.type = 'text/javascript';
          s.setAttribute('data-locale', 'en-us');
          s.setAttribute('data-position', 'bottom-right');
          s.src = 'https://www.roomvo.com/static/scripts/b2b/common/assistant.js';
          document.body.appendChild(s);
        }
        var fired = false;
        function go() {
          if (fired) return;
          fired = true;
          if ('requestIdleCallback' in window) requestIdleCallback(loadRoomvo, { timeout: 2000 });
          else setTimeout(loadRoomvo, 200);
        }
        // Load on the first real user interaction. Real visitors move/scroll
        // within ~1s (widget appears promptly); keeps the third-party off the
        // initial paint entirely.
        ['scroll', 'pointermove', 'pointerdown', 'keydown', 'touchstart', 'mousemove'].forEach(function (ev) {
          window.addEventListener(ev, go, { once: true, passive: true });
        });
      })();
    </script>
  </body>
</html>
