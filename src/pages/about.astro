---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import WhyUs from '../components/WhyUs.astro';
import CtaBand from '../components/CtaBand.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
---
<BaseLayout
 title="About Floors To You OKC | Family-Owned OKC Flooring Store | Since 2018"
 description="Floors To You OKC is Oklahoma City's locally-owned flooring showroom on West Reno Ave. Meet our installers, design consultants, and 100% product + labor guarantee."
>
 <Breadcrumb items={[{ name: 'Home', url: '/' }, { name: 'About', url: '/about' }]} />

 <section class="container-x py-12 grid lg:grid-cols-2 gap-12 items-center">
 <div>
 <p class="eyebrow mb-3">About Us</p>
 <h1 class="mb-5">Oklahoma City's Flooring Showroom Since 2018</h1>
 <p class="text-lg text-ink/80 leading-relaxed mb-4">Floors To You OKC opened on West Reno Avenue with a simple promise: stop the upselling, stop the special-order delays, and keep so much flooring in stock that any Oklahoma homeowner can pick a floor today and walk on it this week.</p>
 <p class="text-ink/80 leading-relaxed mb-4">Seven years and 2,500+ local installs later, we are still the metro's largest in-stock showroom - and our W-2 installers still wrap every floor with the same 100% product and labor guarantee we started with.</p>
 <a href="/free-in-home-estimate" class="btn-primary mt-4">Meet Us In The Showroom</a>
 </div>
 <img src="/images/photos/team/teamworking.webp" alt="Floors To You OKC installation team measuring and laying new floors in an Oklahoma City home" width="900" height="700" loading="lazy" class="rounded-xl2 shadow-soft w-full h-auto object-cover aspect-[4/3]" />
 </section>

 <WhyUs />

 <section class="bg-brand-50">
 <div class="container-x py-16 md:py-24 grid md:grid-cols-3 gap-8">
 <div>
 <h3 class="text-2xl mb-2">Our Showroom</h3>
 <p class="text-ink/75 leading-relaxed">4020 West Reno Avenue, just off I-44. Hundreds of full-size samples to walk on, plus 30+ in-stock SKUs ready to ship.</p>
 </div>
 <div>
 <h3 class="text-2xl mb-2">Our Crews</h3>
 <p class="text-ink/75 leading-relaxed">Lead installers are W-2 employees. Every floor we install is backed by a 100% labor guarantee.</p>
 </div>
 <div>
 <h3 class="text-2xl mb-2">Our Promise</h3>
 <p class="text-ink/75 leading-relaxed">No upsells, no surprise charges. Itemized written quotes - and a price-match guarantee on any matching SKU in Oklahoma.</p>
 </div>
 </div>
 </section>

 <CtaBand />

 <Fragment slot="head">
 <BreadcrumbSchema items={[{ name: 'Home', url: '/' }, { name: 'About', url: '/about' }]} />
 </Fragment>
</BaseLayout>
