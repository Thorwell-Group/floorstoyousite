---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CtaBand from '../components/CtaBand.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
import { testimonials, googleReviewsUrl } from '../data/testimonials';
import { site } from '../data/site';

const reviewSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${site.domain}/#business`,
  name: site.name,
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: 187 },
  review: testimonials.map((t) => ({
    '@type': 'Review',
    reviewRating: { '@type': 'Rating', ratingValue: t.rating, bestRating: 5 },
    author: { '@type': 'Person', name: t.name },
    reviewBody: t.body,
    ...(t.date && { datePublished: t.date }),
  })),
};
---
<BaseLayout
  title="Reviews | Floors To You OKC | 5-Star Flooring Installer in Oklahoma City"
  description="Real Oklahoma City homeowners share their Floors To You OKC experience. 4.9-star average across carpet, hardwood, LVP, laminate & tile installs across the metro."
>
  <Breadcrumb items={[{ name: 'Home', url: '/' }, { name: 'Reviews', url: '/reviews' }]} />

  <section class="container-x py-12">
    <p class="eyebrow mb-3">Customer Reviews</p>
    <h1>What OKC Homeowners Say</h1>
    <p class="text-lg text-ink/80 mt-4 max-w-2xl">Floors To You OKC averages 4.9 stars across hundreds of installs in Oklahoma City, Edmond, Yukon, Mustang, Moore, and Norman.</p>
  </section>

  <section class="container-x pb-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {testimonials.map((t) => (
        <article class="card p-6 flex flex-col">
          <header class="flex items-start justify-between gap-3 mb-3">
            <div class="flex items-center gap-3">
              <div class="grid place-items-center w-10 h-10 rounded-full bg-brand-500 text-white font-semibold text-sm" aria-hidden>
                {t.name.split(' ').map((n) => n[0]).slice(0, 2).join('')}
              </div>
              <div>
                <p class="font-semibold text-brand-800 leading-tight">{t.name}</p>
                {t.meta && <p class="text-xs text-ink/55">{t.meta}</p>}
              </div>
            </div>
            <div class="text-brand-500 text-sm" aria-label={`${t.rating} of 5 stars`}>{'★'.repeat(t.rating)}</div>
          </header>
          <p class="text-ink/85 leading-relaxed text-sm">&ldquo;{t.body}&rdquo;</p>
          {(t.date || t.city || t.product) && (
            <p class="text-xs text-ink/55 border-t border-brand-100 pt-3 mt-4">{[t.date, t.city, t.product].filter(Boolean).join(' · ')}</p>
          )}
          {t.ownerReply && (
            <div class="mt-3 p-3 rounded-lg bg-brand-50">
              <p class="text-[11px] font-semibold uppercase tracking-wide text-brand-700 mb-1">Owner reply</p>
              <p class="text-xs text-ink/75 leading-relaxed">{t.ownerReply}</p>
            </div>
          )}
        </article>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href={googleReviewsUrl} target="_blank" rel="noopener" class="btn-primary">
        <span aria-hidden>★</span> See Every Review On Google
      </a>
    </div>
  </section>

  <CtaBand headline="Ready to write your own 5-star review?" subline="Book a free in-home estimate and we'll show you how easy it is." />

  <Fragment slot="head">
    <BreadcrumbSchema items={[{ name: 'Home', url: '/' }, { name: 'Reviews', url: '/reviews' }]} />
    <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />
  </Fragment>
</BaseLayout>
