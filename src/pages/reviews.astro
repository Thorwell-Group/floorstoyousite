---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CtaBand from '../components/CtaBand.astro';
import ReviewCards from '../components/ReviewCards.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
---
<BaseLayout
  title="Reviews | Floors To You OKC | Oklahoma City Flooring Installer"
  description="Read verified reviews for Floors To You OKC on Google. See what Oklahoma City homeowners say about our carpet, hardwood, LVP, laminate & tile installs across the metro."
>
  <Breadcrumb items={[{ name: 'Home', url: '/' }, { name: 'Reviews', url: '/reviews' }]} />

  <section class="container-x py-16">
    <div class="max-w-2xl mx-auto text-center">
      <p class="eyebrow mb-3">Customer Reviews</p>
      <h1>What OKC Homeowners Say</h1>
      <p class="text-lg text-ink/80 mt-4">We let our work - and our customers - speak for themselves. Here's what verified Oklahoma City homeowners say about Floors To You OKC.</p>
    </div>

    <ReviewCards class="mt-12 max-w-5xl mx-auto" />
  </section>

  <CtaBand headline="Ready to write your own 5-star review?" subline="Book a free in-home estimate and we'll show you how easy it is." />

  <Fragment slot="head">
    <BreadcrumbSchema items={[{ name: 'Home', url: '/' }, { name: 'Reviews', url: '/reviews' }]} />
  </Fragment>
</BaseLayout>
