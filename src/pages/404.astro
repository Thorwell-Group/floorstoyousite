---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found | Floors To You OKC" description="The page you're looking for doesn't exist." noindex>
  <section class="container-x py-24 text-center">
    <p class="eyebrow mb-3">404</p>
    <h1 class="mb-4">We can't find that floor.</h1>
    <p class="text-lg text-ink/80 mb-8">The page you're looking for may have been moved. Head back home or browse our flooring.</p>
    <div class="flex justify-center gap-3">
      <a href="/" class="btn-primary">Go Home</a>
      <a href="/services" class="btn-outline">Shop Flooring</a>
    </div>
  </section>
</BaseLayout>
