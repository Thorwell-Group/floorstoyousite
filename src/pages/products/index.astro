---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import BreadcrumbSchema from '../../components/schema/BreadcrumbSchema.astro';
---
<BaseLayout
  title="Shop All Flooring | Browse Carpet, Wood, Tile & Vinyl | Floors To You OKC"
  description="Browse our full flooring catalog — carpet, engineered wood, laminate, tile and vinyl. Filter by type and color, then preview any style in your own room with the visualizer. Free in-home estimate."
>
  <Breadcrumb items={[{ name: 'Home', url: '/' }, { name: 'Shop Flooring', url: '/products' }]} />

  <section class="container-x pt-10 pb-6">
    <p class="eyebrow mb-3">Shop The Showroom</p>
    <h1 class="mb-4">Browse Our Full Flooring Catalog</h1>
    <p class="text-lg text-ink/80 max-w-3xl">Filter by type and color to find your floor fast — carpet, engineered wood, laminate, tile and vinyl. Tap any style to preview it in a room like yours with the visualizer, then book a free in-home estimate to see real samples in your space.</p>
  </section>

  {/* Roomvo Product Catalog — the same browse + filter + visualize experience
      across our whole product line. The Roomvo assistant script (loaded in
      BaseLayout) renders the catalog widget into #roomvoCatalog and resolves
      our store automatically. */}
  <section class="container-x pb-16">
    <a id="catalog"></a><div id="roomvoCatalog"></div>
  </section>

  <CtaBand headline="See a floor you love?" subline="Book a free in-home estimate and we'll bring samples to match your light + trim." />

  <Fragment slot="head">
    <BreadcrumbSchema items={[{ name: 'Home', url: '/' }, { name: 'Shop Flooring', url: '/products' }]} />
  </Fragment>
</BaseLayout>
