---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import BreadcrumbSchema from '../../components/schema/BreadcrumbSchema.astro';
import { products, productCategories, productsByCategory } from '../../data/products';
import { colorFamilies, colorsForName } from '../../data/productColors';

// Enrich each product with an inferred color set so tiles can carry the data
// attributes the client-side filter reads.
const enriched = products.map((p) => ({ ...p, colors: colorsForName(p.name) }));

// Sidebar facets: Product Type (always show the 6 categories) and Color
// (only families that actually have stock, so we never show an empty filter).
const typeFacets = productCategories
  .map((c) => ({ ...c, count: productsByCategory(c.slug).length }))
  .filter((c) => c.count > 0);

const colorFacets = colorFamilies
  .map((c) => ({ ...c, count: enriched.filter((p) => p.colors.includes(c.slug)).length }))
  .filter((c) => c.count > 0);
---
<BaseLayout
 title={`Shop All Flooring | ${products.length} In-Stock Carpet, Wood, Tile & Vinyl | Floors To You OKC`}
 description={`Browse all ${products.length} in-stock flooring SKUs at Floors To You OKC - filter by type and color. Carpet, engineered wood, laminate, tile, vinyl glue & vinyl click. Free in-home estimate.`}
>
 <Breadcrumb items={[{ name: 'Home', url: '/' }, { name: 'Shop Flooring', url: '/products' }]} />

 <section class="container-x pt-10 pb-6">
 <p class="eyebrow mb-3">Shop The Showroom</p>
 <h1 class="mb-4">All In-Stock Flooring · {products.length} SKUs</h1>
 <p class="text-lg text-ink/80 max-w-2xl">Filter by type and color to find your floor fast. Everything below is in stock at our West Reno Avenue showroom in Oklahoma City - most can install within 24–72 hours of your accepted quote.</p>
 </section>

 <section class="container-x pb-16">
 <div class="lg:grid lg:grid-cols-[260px_1fr] lg:gap-10 items-start">

 {/* Mobile: a button that reveals the filter panel. Hidden on desktop. */}
 <button
 id="filter-toggle"
 type="button"
 aria-expanded="false"
 aria-controls="filter-panel"
 class="lg:hidden w-full mb-4 flex items-center justify-between gap-2 px-4 py-3 rounded-xl2 bg-white ring-1 ring-brand-200 text-brand-800 font-semibold"
 >
 <span class="flex items-center gap-2">
 <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="7" y1="12" x2="17" y2="12"/><line x1="10" y1="18" x2="14" y2="18"/></svg>
 Filter products
 </span>
 <span id="filter-count-badge" class="text-xs font-bold text-white bg-brand-500 rounded-full px-2 py-0.5 hidden">0</span>
 </button>

 {/* Left sidebar — the okfloorpro-style facet list. */}
 <aside
 id="filter-panel"
 class="hidden lg:block lg:sticky lg:top-24 mb-6 lg:mb-0"
 >
 <div class="card p-5 lg:p-6">
 <div class="flex items-center justify-between mb-4">
 <h2 class="text-base font-bold text-brand-800 m-0">Filters</h2>
 <button id="clear-filters" type="button" class="text-xs font-semibold text-brand-600 hover:text-brand-500 underline hidden">Clear all</button>
 </div>

 {/* Search by name */}
 <label class="block mb-6">
 <span class="text-[11px] uppercase tracking-[0.18em] font-bold text-ink/55">Search</span>
 <input
 id="filter-search"
 type="search"
 placeholder="Search by name…"
 autocomplete="off"
 class="mt-2 w-full rounded-lg border border-brand-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400"
 />
 </label>

 {/* Product Type */}
 <fieldset class="mb-6">
 <legend class="text-[11px] uppercase tracking-[0.18em] font-bold text-ink/55 mb-3">Product Type</legend>
 <ul class="space-y-2">
 {typeFacets.map((c) => (
 <li>
 <label class="flex items-center gap-2.5 cursor-pointer group">
 <input type="checkbox" class="f-type accent-brand-500 w-4 h-4 rounded" value={c.slug} />
 <span class="text-sm text-ink/80 group-hover:text-brand-700 flex-1">{c.label}</span>
 <span class="text-xs text-ink/45">{c.count}</span>
 </label>
 </li>
 ))}
 </ul>
 </fieldset>

 {/* Color */}
 <fieldset>
 <legend class="text-[11px] uppercase tracking-[0.18em] font-bold text-ink/55 mb-3">Color</legend>
 <ul class="space-y-2">
 {colorFacets.map((c) => (
 <li>
 <label class="flex items-center gap-2.5 cursor-pointer group">
 <input type="checkbox" class="f-color accent-brand-500 w-4 h-4 rounded" value={c.slug} />
 <span class="w-4 h-4 rounded-full ring-1 ring-black/10 flex-none" style={`background:${c.swatch}`}></span>
 <span class="text-sm text-ink/80 group-hover:text-brand-700 flex-1">{c.label}</span>
 <span class="text-xs text-ink/45">{c.count}</span>
 </label>
 </li>
 ))}
 </ul>
 </fieldset>
 </div>
 </aside>

 {/* Right column — result count + product grid. */}
 <div>
 <p id="result-count" class="text-sm text-ink/65 mb-5">Showing all <strong class="text-brand-800">{products.length}</strong> products</p>

 <div id="product-grid" class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4">
 {enriched.map((p) => {
 const cat = productCategories.find((c) => c.slug === p.category);
 return (
 <a
 href={`/products/${p.slug}`}
 class="product-tile group no-underline text-center"
 data-cat={p.category}
 data-colors={p.colors.join(' ')}
 data-name={p.name.toLowerCase()}
 >
 <div class="aspect-square overflow-hidden rounded-xl2 bg-brand-100 shadow-card">
 <img
 src={p.image}
 alt={`${p.name} ${cat?.label ?? 'flooring'} - in stock at Floors To You OKC`}
 loading="lazy"
 width="400"
 height="400"
 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
 />
 </div>
 <div class="mt-3">
 <p class="text-sm font-semibold text-brand-800 leading-tight group-hover:text-brand-500">{p.name}</p>
 <p class="text-xs text-ink/55 mt-0.5">{cat?.label}</p>
 </div>
 </a>
 );
 })}
 </div>

 {/* Shown only when filters exclude everything. */}
 <div id="no-results" class="hidden text-center py-16">
 <p class="text-lg font-semibold text-brand-800">No products match those filters.</p>
 <p class="text-ink/65 mt-2">Try removing a color or type — or <a href="/book" class="text-brand-700 hover:text-brand-500">book a free in-home estimate</a> and we'll bring samples to you.</p>
 </div>
 </div>

 </div>
 </section>

 <CtaBand headline="See a floor you love?" subline="Book a free in-home estimate and we'll bring samples to match your light + trim." />

 <Fragment slot="head">
 <BreadcrumbSchema items={[{ name: 'Home', url: '/' }, { name: 'Shop Flooring', url: '/products' }]} />
 </Fragment>

 <script is:inline define:vars={{ total: products.length }}>
 (function () {
 const grid = document.getElementById('product-grid');
 if (!grid) return;
 const tiles = Array.from(grid.querySelectorAll('.product-tile'));
 const typeBoxes = Array.from(document.querySelectorAll('.f-type'));
 const colorBoxes = Array.from(document.querySelectorAll('.f-color'));
 const search = document.getElementById('filter-search');
 const countEl = document.getElementById('result-count');
 const noResults = document.getElementById('no-results');
 const clearBtn = document.getElementById('clear-filters');
 const badge = document.getElementById('filter-count-badge');

 const checked = (boxes) => boxes.filter((b) => b.checked).map((b) => b.value);

 function apply() {
 const types = checked(typeBoxes);
 const colors = checked(colorBoxes);
 const q = (search.value || '').trim().toLowerCase();
 let shown = 0;

 tiles.forEach((t) => {
 const matchType = !types.length || types.includes(t.dataset.cat);
 const tileColors = (t.dataset.colors || '').split(' ').filter(Boolean);
 const matchColor = !colors.length || colors.some((c) => tileColors.includes(c));
 const matchSearch = !q || t.dataset.name.includes(q);
 const show = matchType && matchColor && matchSearch;
 t.classList.toggle('hidden', !show);
 if (show) shown++;
 });

 // Result count copy.
 if (shown === total) {
 countEl.innerHTML = `Showing all <strong class="text-brand-800">${total}</strong> products`;
 } else {
 countEl.innerHTML = `Showing <strong class="text-brand-800">${shown}</strong> of ${total} products`;
 }
 noResults.classList.toggle('hidden', shown !== 0);

 // Active-filter affordances (clear button + mobile badge).
 const active = types.length + colors.length + (q ? 1 : 0);
 clearBtn.classList.toggle('hidden', active === 0);
 if (badge) {
 badge.textContent = String(active);
 badge.classList.toggle('hidden', active === 0);
 }
 }

 typeBoxes.forEach((b) => b.addEventListener('change', apply));
 colorBoxes.forEach((b) => b.addEventListener('change', apply));
 search.addEventListener('input', apply);

 clearBtn.addEventListener('click', () => {
 [...typeBoxes, ...colorBoxes].forEach((b) => (b.checked = false));
 search.value = '';
 apply();
 });

 // Mobile filter panel toggle.
 const toggle = document.getElementById('filter-toggle');
 const panel = document.getElementById('filter-panel');
 if (toggle && panel) {
 toggle.addEventListener('click', () => {
 const open = panel.classList.toggle('hidden');
 toggle.setAttribute('aria-expanded', String(!open));
 });
 }

 // Deep-link support: /products?type=tile&color=gray
 const params = new URLSearchParams(window.location.search);
 const preType = (params.get('type') || '').split(',').filter(Boolean);
 const preColor = (params.get('color') || '').split(',').filter(Boolean);
 typeBoxes.forEach((b) => { if (preType.includes(b.value)) b.checked = true; });
 colorBoxes.forEach((b) => { if (preColor.includes(b.value)) b.checked = true; });
 apply();
 })();
 </script>
</BaseLayout>
