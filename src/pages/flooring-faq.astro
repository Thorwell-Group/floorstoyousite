---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FAQ from '../components/FAQ.astro';
import CtaBand from '../components/CtaBand.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
import FAQSchema from '../components/schema/FAQSchema.astro';
import { generalFaqs } from '../data/faqs';
import { services } from '../data/services';

const allFaqs = [
 ...generalFaqs,
 ...services.flatMap((s) => s.faqs.map((f) => ({ q: `${s.shortName}: ${f.q}`, a: f.a }))),
];
---
<BaseLayout
 title="Flooring FAQ Oklahoma City | Answers To Your Top Questions | Floors To You OKC"
 description="Costs, timelines, warranty, financing, install - every question OKC homeowners ask about new flooring, answered by Floors To You OKC."
>
 <Breadcrumb items={[{ name: 'Home', url: '/' }, { name: 'FAQ', url: '/flooring-faq' }]} />
 <section class="container-x py-12">
 <p class="eyebrow mb-3">FAQ</p>
 <h1 class="mb-4">Oklahoma City Flooring FAQ</h1>
 <p class="text-lg text-ink/80 max-w-2xl">Everything from "how fast can you install?" to "is LVP really waterproof?" - answered by the Floors To You OKC team.</p>
 </section>

 <FAQ faqs={allFaqs} eyebrow="" heading="Every Question We Get, Answered" />

 <CtaBand />

 <Fragment slot="head">
 <BreadcrumbSchema items={[{ name: 'Home', url: '/' }, { name: 'FAQ', url: '/flooring-faq' }]} />
 <FAQSchema faqs={allFaqs} />
 </Fragment>
</BaseLayout>
