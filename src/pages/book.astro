---
import FunnelLayout from '../layouts/FunnelLayout.astro';
import { site } from '../data/site';
import { testimonials } from '../data/testimonials';

const title = 'Book A Free In-Home Flooring Estimate · Floors To You OKC';
const description = `Oklahoma City's largest in-stock flooring showroom comes to you. Free in-home measure, written quote, next-day install on in-stock material, 0% financing for 24 months.`;
---
<FunnelLayout title={title} description={description}>
  {/* HERO - form first on mobile so it is the first thing visible. No marquee, no preamble. */}
  <section class="relative isolate overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-br from-cream via-brand-50 to-cream"></div>
    <div class="absolute -top-32 -right-32 -z-10 h-[36rem] w-[36rem] rounded-full bg-brand-300/30 blur-3xl" aria-hidden="true"></div>
    <div class="absolute -bottom-32 -left-32 -z-10 h-[28rem] w-[28rem] rounded-full bg-brand-500/10 blur-3xl" aria-hidden="true"></div>

    <div class="container-x pt-4 pb-10 lg:pt-10 lg:pb-16">
      <div class="grid lg:grid-cols-[1.05fr_1fr] gap-8 lg:gap-12 items-center">

        {/* Form card - order-1 on mobile so it sits at the very top under the header. */}
        <div class="order-1 lg:order-2 reveal reveal-right" id="form">
          <div class="rounded-xl2 bg-white ring-1 ring-brand-200 shadow-soft overflow-hidden">
            <div class="bg-gradient-to-r from-brand-700 to-brand-800 text-white px-5 py-3 sm:px-6 sm:py-4">
              <div class="text-[10px] sm:text-[11px] uppercase tracking-[0.22em] font-bold text-brand-300">Free · No obligation</div>
              <div class="font-display text-lg sm:text-xl font-bold mt-0.5">Book your free in-home estimate</div>
            </div>

            {/* GHL Booking Survey embed. form_embed.js auto-resizes via postMessage. */}
            <iframe
              src="https://api.leadconnectorhq.com/widget/survey/jWARw7xCkBcUAI4uUldA"
              scrolling="no"
              id="jWARw7xCkBcUAI4uUldA"
              title="Book a free in-home flooring estimate"
              loading="eager"
              fetchpriority="high"
              style="border:0;width:100%;height:560px;display:block;background:#fff;"
            ></iframe>
          </div>
        </div>

        {/* Headline - below the form on mobile, beside it on desktop. */}
        <div class="order-2 lg:order-1 reveal reveal-left">
          <h1 class="font-display font-bold leading-[1.02] tracking-tight text-3xl sm:text-4xl lg:text-5xl xl:text-6xl text-brand-800">
            Free
            <span class="block text-brand-500">In-Home</span>
            <span class="block">Flooring Estimate.</span>
          </h1>

          <p class="mt-5 text-base sm:text-lg text-ink/80 leading-relaxed max-w-xl">
            <strong class="text-brand-800">The showroom comes to you.</strong> Samples matched to your light and trim, a written quote, and zero pressure.
          </p>

          <ul class="mt-5 space-y-2 text-sm sm:text-base text-ink/80">
            <li class="flex items-center gap-2"><span class="text-brand-500" aria-hidden>✓</span> Next-day install on in-stock material</li>
            <li class="flex items-center gap-2"><span class="text-brand-500" aria-hidden>✓</span> 0% APR financing for 24 months</li>
            <li class="flex items-center gap-2"><span class="text-brand-500" aria-hidden>✓</span> 100% product &amp; labor guarantee</li>
          </ul>
        </div>

      </div>
    </div>

    {/* Form embed script + post-submit redirect to the calendar page. */}
    <script src="https://link.msgsndr.com/js/form_embed.js" is:inline async></script>
    <script is:inline>
      const FTY_BOOK_REDIRECT = '/book-estimate';
      let ftyRedirected = false;
      window.addEventListener('message', (e) => {
        if (!e.origin || !/leadconnectorhq\.com|msgsndr\.com/.test(e.origin)) return;
        const d = e.data;
        const submitted =
          (typeof d === 'string' && /submit/i.test(d)) ||
          (d && (d.type === 'form_submit_redirect' || d.type === 'survey_submit_redirect' || d.type === 'form_submit_action' || /submit/i.test(d.event || d.type || '')));
        if (submitted && !ftyRedirected) {
          ftyRedirected = true;
          window.top.location.href = FTY_BOOK_REDIRECT;
        }
      });
    </script>
  </section>

  {/* SOCIAL PROOF BAND */}
  <section class="bg-brand-900 text-white py-12 lg:py-16 relative overflow-hidden">
    <div class="absolute top-0 inset-x-0 h-[2px] bg-brand-500"></div>
    <div class="absolute bottom-0 inset-x-0 h-[2px] bg-brand-500"></div>
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto reveal">
        <h2 class="text-white font-display text-2xl sm:text-3xl lg:text-4xl font-bold leading-tight">
          4.9 stars · 187+ verified reviews.
        </h2>
        <p class="mt-3 text-white/80 text-sm sm:text-base">Real Oklahoma homeowners. Real installs.</p>
      </div>

      <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {testimonials.slice(0, 6).map((r, i) => (
          <li class={`reveal reveal-zoom reveal-d${(i % 3) + 1} rounded-xl2 bg-white/5 ring-1 ring-white/10 p-6 backdrop-blur`}>
            <div class="flex items-center gap-3">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-brand-500 text-white font-display font-bold text-sm">
                {r.name.split(' ').map((p) => p[0]).slice(0, 2).join('')}
              </span>
              <div class="leading-tight">
                <div class="font-semibold text-sm">{r.name}</div>
                {r.city && <div class="text-[11px] text-white/60">{r.city}</div>}
              </div>
              <div class="ml-auto flex items-center gap-0.5 text-brand-400">
                {Array.from({ length: r.rating }).map(() => (
                  <svg aria-hidden="true" focusable="false" width="12" height="12" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L10 14.9 4.7 17.6l1-5.8L1.5 7.7l5.9-.9z"/></svg>
                ))}
              </div>
            </div>
            <p class="mt-4 text-sm text-white/85 leading-relaxed line-clamp-5">"{r.body}"</p>
          </li>
        ))}
      </ul>

      <div class="mt-8 text-center">
        <a href="#form" class="inline-flex items-center gap-2 rounded-xl2 bg-brand-500 hover:bg-brand-600 px-6 py-3 font-semibold text-white text-sm no-underline">
          Book my free estimate
          <svg aria-hidden="true" focusable="false" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  {/* STATS BAND */}
  <section class="bg-cream py-12 lg:py-16">
    <div class="container-x">
      <ul class="grid grid-cols-2 lg:grid-cols-4 gap-y-8 gap-x-6 text-center">
        {[
          { v: 2500, suf: '+', label: 'Local installs' },
          { v: 187, suf: '+', label: '5-star reviews' },
          { v: 24, suf: 'hr', label: 'Install turnaround' },
          { v: 0, suf: '% APR', label: '24-month financing' },
        ].map((s, i) => (
          <li class={`reveal reveal-zoom reveal-d${(i % 3) + 1}`}>
            <div class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-brand-500 leading-none">
              <span data-count={s.v} data-suffix={s.suf}>0{s.suf}</span>
            </div>
            <div class="mt-3 text-[11px] uppercase tracking-[0.22em] text-brand-800 font-semibold">{s.label}</div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* WHAT HAPPENS NEXT */}
  <section class="bg-brand-50 py-12 lg:py-16">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto mb-10 reveal">
        <h2 class="font-display text-2xl sm:text-3xl lg:text-4xl font-bold text-brand-800 leading-tight">
          What happens next.
        </h2>
      </div>
      <ol class="grid gap-6 md:grid-cols-3 max-w-5xl mx-auto">
        {[
          { n: '01', t: 'We call to confirm', b: 'A real person reaches out within one business hour.' },
          { n: '02', t: 'We come to you', b: 'A design consultant arrives with samples matched to your light and trim.' },
          { n: '03', t: 'Written, itemized quote', b: 'Take it, leave it, sleep on it. No pressure, no upselling.' },
        ].map((s, i) => (
          <li class={`reveal reveal-zoom reveal-d${i + 1} rounded-xl2 bg-white ring-1 ring-brand-200 shadow-card p-6 sm:p-7`}>
            <div class="font-display text-3xl font-bold text-brand-500">{s.n}</div>
            <h3 class="mt-2 font-display text-lg font-bold text-brand-800">{s.t}</h3>
            <p class="mt-2 text-sm text-ink/80 leading-relaxed">{s.b}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* FINANCING BAND */}
  <section class="relative isolate overflow-hidden text-white">
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-brand-900 via-brand-800 to-brand-700"></div>
    <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-brand-500 -z-10"></div>
    <div class="container-x py-12 lg:py-16 grid lg:grid-cols-[1.4fr_1fr] gap-8 items-center">
      <div class="reveal reveal-left">
        <h2 class="text-white font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight">
          0% APR for 24 months.
        </h2>
        <p class="mt-3 text-white/85 max-w-xl">
          Pre-qualify in 90 seconds. No credit impact.
        </p>
      </div>
      <a href="#form" class="reveal reveal-right reveal-d2 inline-flex items-center justify-center btn bg-white text-brand-800 hover:bg-brand-50 px-7 py-4 text-base font-bold shadow-soft no-underline">
        Book my estimate
        <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>

  {/* OBJECTION HANDLERS */}
  <section class="bg-cream py-12 lg:py-16">
    <div class="container-x max-w-3xl">
      <div class="text-center mb-10 reveal">
        <h2 class="font-display text-2xl sm:text-3xl lg:text-4xl font-bold text-brand-800 leading-tight">
          Quick answers.
        </h2>
      </div>
      <ul class="divide-y divide-brand-100 ring-1 ring-brand-200 rounded-xl2 bg-white shadow-card overflow-hidden">
        {[
          { q: 'Is the in-home estimate really free?', a: 'Yes. No obligation, no hidden fees, no high-pressure sales pitch.' },
          { q: 'Will I get spammed?', a: 'No. One call to confirm, one to follow up after install. That is it.' },
          { q: 'How fast can you install?', a: 'Next-day install on in-stock material. Most quotes can install within 5 business days.' },
          { q: 'Which areas do you serve?', a: 'Oklahoma City, Edmond, Yukon, Mustang, Midwest City, Moore, Norman, Guthrie and the rest of the OKC metro within 50 miles.' },
        ].map((f) => (
          <li>
            <details class="group">
              <summary class="flex items-center justify-between gap-4 px-5 sm:px-6 py-4 sm:py-5 cursor-pointer list-none">
                <span class="font-display font-semibold text-base text-brand-800">{f.q}</span>
                <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-500 transition-transform group-open:rotate-180 flex-none"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <p class="px-5 sm:px-6 pb-5 -mt-1 text-sm text-ink/80 leading-relaxed">{f.a}</p>
            </details>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* FINAL CTA */}
  <section class="relative isolate overflow-hidden text-white">
    <div class="absolute inset-0 -z-10 bg-brand-900"></div>
    <div class="absolute -top-32 -right-32 -z-10 h-[28rem] w-[28rem] rounded-full bg-brand-500/25 blur-3xl"></div>
    <div class="absolute -bottom-32 -left-32 -z-10 h-[24rem] w-[24rem] rounded-full bg-brand-500/15 blur-3xl"></div>

    <div class="container-x py-14 lg:py-20 text-center max-w-3xl mx-auto reveal">
      <h2 class="text-white font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight">
        Book in 90 seconds.
      </h2>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="#form" class="btn bg-brand-500 text-white hover:bg-brand-600 px-7 py-4 text-base font-bold shadow-soft no-underline">
          Book my free estimate
        </a>
        <a href={site.emailHref} class="btn bg-transparent text-white ring-2 ring-white hover:bg-white hover:text-brand-800 px-7 py-4 text-base no-underline">
          Email {site.email}
        </a>
      </div>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-[11px] uppercase tracking-[0.22em] text-white/60 font-semibold">
        <span>Locally Owned</span>
        <span class="opacity-30">·</span>
        <span>100% Guarantee</span>
        <span class="opacity-30">·</span>
        <span>Next-Day Install</span>
        <span class="opacity-30">·</span>
        <span>0% APR · 24mo</span>
      </div>
    </div>
  </section>
</FunnelLayout>
