---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Hero from '../../components/Hero.astro';
import Gallery from '../../components/Gallery.astro';
import VisualizerBand from '../../components/VisualizerBand.astro';
import ProofBand from '../../components/ProofBand.astro';
import AreaGrid from '../../components/AreaGrid.astro';
import Testimonials from '../../components/Testimonials.astro';
import FAQ from '../../components/FAQ.astro';
import CtaBand from '../../components/CtaBand.astro';
import BreadcrumbSchema from '../../components/schema/BreadcrumbSchema.astro';
import FAQSchema from '../../components/schema/FAQSchema.astro';
import { proofTopics } from '../../data/proof';

export function getStaticPaths() {
  return proofTopics.map((t) => ({ params: { topic: t.slug }, props: { topic: t } }));
}
const { topic: t } = Astro.props;
const others = proofTopics.filter((o) => o.slug !== t.slug);

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'The Proof', url: '/the-proof/' },
  { name: t.label, url: `/proof/${t.slug}/` },
];
---
<BaseLayout title={t.metaTitle} description={t.metaDescription}>
  <Breadcrumb items={breadcrumbs} />

  <Hero
    eyebrow={t.eyebrow}
    title={t.h1}
    subtitle={t.intro}
    image={t.hero}
    imageAlt={t.heroAlt}
    ctaPrimary={{ label: 'Get My Free Estimate', href: '/book/' }}
    ctaSecondary={{ label: 'See It In Your Room', href: '/catalog/' }}
  />

  {/* Headline stat strip */}
  <section class="bg-brand-800 text-white">
    <div class="container-x py-8 grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
      {t.stats.map((s) => (
        <div>
          <p class="font-display text-3xl sm:text-4xl text-brand-300">{s.value}</p>
          <p class="text-sm text-white/80 mt-1">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  {/* How our floors account for it */}
  <section class="container-x py-16 md:py-20">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <p class="eyebrow mb-3">{t.label}</p>
      <h2>{t.howHeading}</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-5 max-w-5xl mx-auto">
      {t.how.map((h) => (
        <div class="rounded-xl2 bg-white ring-1 ring-brand-100 shadow-card p-6 sm:p-7">
          <div class="flex items-start gap-4">
            <span class="grid place-items-center w-11 h-11 flex-none rounded-full bg-brand-500 text-white" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </span>
            <div>
              <h3 class="text-xl mb-2">{h.title}</h3>
              <p class="text-ink/80 leading-relaxed">{h.body}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* Best floors for this */}
    <div class="mt-12 text-center">
      <p class="eyebrow mb-4">Best Floors For This</p>
      <div class="flex flex-wrap justify-center gap-2.5">
        {t.bestFloors.map((f) => (
          <span class="px-4 py-2 rounded-full bg-brand-50 ring-1 ring-brand-100 text-brand-800 text-sm font-medium">{f}</span>
        ))}
      </div>
    </div>
  </section>

  <Gallery
    items={t.gallery}
    eyebrow={`${t.label} Gallery`}
    heading={`${t.label} Floors Installed Across OKC`}
    subhead={`Recent ${t.label.toLowerCase()} projects we've completed across Oklahoma City and the metro.`}
  />

  <VisualizerBand />

  <ProofBand />

  {/* Explore the rest of The Proof */}
  <section class="bg-cream py-16 md:py-20">
    <div class="container-x">
      <div class="text-center max-w-3xl mx-auto mb-10">
        <p class="eyebrow mb-3">The Proof</p>
        <h2>Proofed Against Everything Else, Too</h2>
        <p class="mt-4 text-lg text-ink/75 leading-relaxed">Pets, kids, water, wear and mess - explore how Floors To You stands up to all of it.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-5xl mx-auto">
        {others.map((o) => (
          <a href={`/proof/${o.slug}/`} class="group block rounded-xl2 overflow-hidden ring-1 ring-brand-100 bg-white shadow-card hover:shadow-soft transition-shadow no-underline">
            <img src={o.hero} alt={o.heroAlt} loading="lazy" width="600" height="400" class="w-full h-40 object-cover" />
            <div class="p-5">
              <h3 class="text-lg text-brand-800 group-hover:text-brand-700">{o.label}</h3>
              <p class="mt-1 text-sm text-ink/70">{o.navLabel} flooring →</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <AreaGrid />
  <Testimonials />
  <FAQ faqs={t.faqs} heading={`${t.label} Flooring Questions OKC Homeowners Ask`} />
  <CtaBand headline={t.ctaHeadline} subline={t.ctaSubline} />

  <Fragment slot="head">
    <BreadcrumbSchema items={breadcrumbs} />
    <FAQSchema faqs={t.faqs} />
  </Fragment>
</BaseLayout>
